{
  "dependency-search-paths":  [ "lib" ],
  "dependencies":  [ "raylib6" ],
  "authors":  [ "John Doe <john.doe@example.com>" ],
  "version": "0.1.0",
  "sources":  [ "src/**" ],
  "build-dir": "build",
  "targets": {
    "default": {
      "name": "mygame",
      "type": "executable",
      "output": "build/default"
    },
    "release": {
      "name": "mygame",
      "type": "executable",
      "opt": "O2",
      "debug-info": "none",
      "link-args":  [ "-s" ],
      "output": "build/release"
    },
    "windows": {
      "name": "mygame",
      "type": "executable",
      "target": "windows-x64",
      "output": "build/windows"
    },
    "windows-release": {
      "name": "mygame",
      "type": "executable",
      "target": "windows-x64",
      "opt": "O2",
      "debug-info": "none",
      "link-args":  [ "-s" ],
      "output": "build/windows-release"
    },
    "web": {
      "type": "executable",
      "name": "index.html",
      "target": "emscripten",
      "link-args":  [
        "--preload-file assets@assets",
        "-sUSE_GLFW=3",
        "-sEXPORTED_RUNTIME_METHODS=['HEAPF32']",
        "--shell-file src/minshell.html"
      ],
      "output": "build/web"
    },
    "web-release": {
      "type": "executable",
      "name": "index.html",
      "target": "emscripten",
      "link-args":  [ 
        "--preload-file assets@assets",
        "-sUSE_GLFW=3",
        "-sEXPORTED_RUNTIME_METHODS=['HEAPF32']",
        "--shell-file src/minshell.html",
        "-O3",
        "-s",
        "-g0"
      ],
      "output": "build/web-release"
    }
  },
  "cpu": "generic",
  "opt": "O0",
  "debug-info": "full"
}